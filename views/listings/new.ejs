<% layout('layouts/boilerplate') %>

<div class="row mt-3">
    <div class="col-8 offset-2">
        <h2 class="mb-4">Create a New Listing</h2>
        <form action="/listings" method="POST" novalidate class="needs-validation">
            
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="title" placeholder="Catchy Title" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="description" class="form-control" placeholder="Describe the place..." rows="4" required></textarea>
            </div>

            <div class="mb-3">
                <label for="image" class="form-label">Image Link (URL)</label>
                <input type="text" name="image" placeholder="https://unsplash.com/..." class="form-control">
            </div>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input type="number" name="price" placeholder="1200" class="form-control" required>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="location" placeholder="Jaipur, Rajasthan" class="form-control" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="country" placeholder="India" class="form-control" required>
            </div>

            <button type="submit" class="btn btn-dark add-btn mt-3 mb-5">Create Listing</button>
        </form>
    </div>
</div>